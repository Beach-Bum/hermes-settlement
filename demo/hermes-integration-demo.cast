[0.038086, "o", "\r\n\u001b[1m\u001b[36m======================================================================\u001b[0m\r\n\u001b[1m\u001b[36m  Hermes Agent + Settlement Toolset Demo\u001b[0m\r\n\u001b[1m\u001b[36m======================================================================\u001b[0m\r\n\r\n  Model:    hermes3:8b (Ollama, local)\r\n  Toolset:  settlement (ERC-8004 + Bittensor)\r\n  Registry: Hermes tools/registry.py\r\n\r\n"]
[0.039395, "o", "  Registered tools: ['settlement_balance', 'settlement_record_task', 'settlement_register', 'settlement_reputation', 'settlement_subnet_info', 'settlement_transfer']\r\n"]
